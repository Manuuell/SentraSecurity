# URL base de la API REST. Vacío = mismo origen (en dev, el proxy de Vite redirige /api a localhost:8000)
VITE_API_URL=

# URL del WebSocket. Vacío = derivada del origen actual: ws(s)://<host>/api/ws
VITE_WS_URL=

# URL del OSRM propio para ajustar rutas a vías (p. ej. http://IP:5000).
# Vacío = demo público de OSRM (solo desarrollo: 10 coords/petición, sin SLA)
VITE_OSRM_URL=

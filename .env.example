# Copia este archivo a .env y completa los valores (.env está en .gitignore)

# Contraseña de PostgreSQL (genera una: openssl rand -base64 24)
POSTGRES_PASSWORD=

# Clave de firma de los JWT (genera una: openssl rand -hex 32)
SECRET_KEY=

# Orígenes permitidos para CORS en producción, separados por coma
# p. ej. https://app.sentrasecurity.co  (en dev puede quedar *)
CORS_ORIGINS=*

# Opcionales (defaults sensatos en docker-compose.yml)
# POSTGRES_DB=sentra_gps
# POSTGRES_USER=sentra
